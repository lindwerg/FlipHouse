# =============================================================================
# FlipHouse — environment variable reference (.env.example)
#
# EVERY env var the platform reads, grouped by service. Values here are
# PLACEHOLDERS ONLY — never commit a real secret. Each var is tagged:
#
#   # SECRET                  never in repo/logs; provision in Railway/KMS, rotate if leaked
#   # _PRIVATE_ (Railway private net)  use the *_PRIVATE_* host so traffic stays on Railway's
#                              private network (no egress fee, not internet-exposed)
#   # public (NEXT_PUBLIC_)   compiled into the browser bundle — assume world-readable
#   # founder-gated           only needed once the GPU/tusd/on-chain lanes go live
#
# Accurate to the real env-resolution code (do NOT hand-edit divergently):
#   web:              apps/web/src/libs/Env.ts (t3-env + zod)
#   cpu-worker:       apps/worker-node/src/r2/build-r2-client.ts (resolveR2Env),
#                     run-workers.ts (DATABASE_URL/REDIS_URL),
#                     apps/worker-node/src/gpu/asr-env.ts (resolveAsrEnv)
#   hook-receiver:    apps/hook-receiver/src/server.ts (requireEnv)
#   webhook-receiver: apps/webhook-receiver/src/server.ts (requireEnv) + resolveR2Env
#   gpu-gigaam:       services/gpu-gigaam/README.md (founder-gated)
#
# A misconfigured deploy FAILS FAST at boot (each resolver throws naming the
# first missing var) — it never silently runs half-wired.
# =============================================================================

# -----------------------------------------------------------------------------
# Managed infrastructure (shared by every Node service)
# -----------------------------------------------------------------------------
# Postgres ledger — the single source of truth (upload_ledger, clips, billing).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway   # SECRET # _PRIVATE_ (Railway private net)

# Redis — BullMQ Flow queues, QueueEvents, and the park:<id> GETDEL dedup.
# NOTE the two names: the receivers + cpu-worker read REDIS_URL; web reads
# REDIS_PRIVATE_URL. Point BOTH at the same managed Redis (the *_PRIVATE_* host).
REDIS_URL=redis://default:PASSWORD@HOST:6379                # SECRET # _PRIVATE_ (Railway private net)
REDIS_PRIVATE_URL=redis://default:PASSWORD@HOST:6379        # SECRET # _PRIVATE_ (Railway private net)

# S3-compatible object storage — source uploads + finished clip artifacts.
# Two supported backends, selected by whether R2_ENDPOINT is set:
#   • Railway Buckets (private, S3-compatible): set R2_ENDPOINT to the bucket's
#     S3 endpoint (e.g. https://t3.storageapi.dev). R2_ACCOUNT_ID is then unused.
#     Reference the bucket's credentials, e.g. R2_BUCKET=${{<bucket>.BUCKET}} etc.
#   • Cloudflare R2: leave R2_ENDPOINT unset; the endpoint is derived as
#     https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com.
# resolveR2Env requires R2_BUCKET/R2_ACCESS_KEY_ID/R2_SECRET_ACCESS_KEY always,
# and R2_ACCOUNT_ID only when R2_ENDPOINT is absent.
R2_ENDPOINT=https://t3.storageapi.dev                      # optional (set for Railway Buckets / non-Cloudflare)
R2_ACCOUNT_ID=your_cloudflare_account_id                   # required ONLY when R2_ENDPOINT is unset
R2_BUCKET=fliphouse-clips                                  #
R2_ACCESS_KEY_ID=your_s3_access_key_id                     # SECRET
R2_SECRET_ACCESS_KEY=your_s3_secret_access_key             # SECRET

# -----------------------------------------------------------------------------
# web (Next.js)  — apps/web/src/libs/Env.ts
# Reads DATABASE_URL + REDIS_PRIVATE_URL (above) plus the following.
# -----------------------------------------------------------------------------
# Clerk auth.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx               # SECRET
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx      # public (NEXT_PUBLIC_)

# Public app + upload/playback wiring handed to the browser.
NEXT_PUBLIC_APP_URL=https://app.fliphouse.example           # public (NEXT_PUBLIC_) (optional)
# tusd resumable-upload endpoint the browser PATCHes bytes to (tusd is founder-gated).
NEXT_PUBLIC_TUS_ENDPOINT=https://uploads.fliphouse.example/files   # public (NEXT_PUBLIC_)
# Clips bucket is PRIVATE: web presigns short-lived GET URLs server-side, so web
# also reads the R2_* server vars above (R2_ENDPOINT/R2_BUCKET/R2_ACCESS_KEY_ID/
# R2_SECRET_ACCESS_KEY). No public bucket base var anymore.

# Logging (Better Stack / pino). Level + optional ingest token/host.
NEXT_PUBLIC_LOGGING_LEVEL=info                              # public (NEXT_PUBLIC_) (optional)
NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=                      # SECRET (optional)
NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=                    # public (optional)

# --- Crypto billing (web) -----------------------------------------------------
# Provider selection. 'mock' = deterministic stub (dev/test default). PRODUCTION
# MUST set 'tron' — the prod-safety guard (selectProvider) THROWS
# MockProviderInProductionError if NODE_ENV=production resolves 'mock', failing
# the deploy instead of silently billing on a stub.
PAYMENT_PROVIDER=mock                                       # set to `tron` in production
# Optional JSON override of the plan grid (prices/minute caps).
BILLING_PLAN_ENV=                                           # (optional)
# Master BIP39 mnemonic for HD deposit-address derivation. The tron provider
# fails loudly at use-time if missing; mock/CI boots without it.
TRON_HD_MNEMONIC=abandon abandon abandon ... about         # SECRET
# TronGrid API key for the on-chain deposit watcher (optional but rate-limited without it).
TRONGRID_API_KEY=                                          # SECRET (optional)
# Deposit-watcher chain config (defaults shown are Nile testnet for checkpoint F).
TRON_RPC_URL=https://nile.trongrid.io                      # (default https://nile.trongrid.io)
TRON_NETWORK=nile                                          # mainnet | nile | shasta (default nile)
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t           # USDT TRC-20 contract (default = mainnet USDT)
TRON_CONFIRMATIONS=19                                      # confirmations before crediting a deposit

# -----------------------------------------------------------------------------
# cpu-worker (apps/worker-node)  — BullMQ consumer, NO HTTP port
# Reads DATABASE_URL, REDIS_URL, R2_* (above), the GPU-lane vars below, plus
# drain knobs. resolveR2Env + run-workers fail-fast at boot.
# -----------------------------------------------------------------------------
# OpenRouter LLM key — read by the Python AI sidecar (os.environ["OPENROUTER_API_KEY"]
# in services/ai-worker-python) for clip scoring. Must be injected into the
# cpu-worker container so the spawned Python stages can reach it.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx            # SECRET

# GPU ASR park-lane (apps/worker-node/src/gpu/asr-env.ts). When GPU_ASR_ENABLED
# !== "true" the inline CPU faster-whisper path runs and the next 3 are unused.
# When ="true", resolveAsrEnv THROWS the deploy if any of the 3 is missing.
GPU_ASR_ENABLED=false                                      # "true" arms the GPU submit-and-park lane
GIGAAM_ENDPOINT=https://gpu-gigaam.fliphouse.example       # founder-gated (worker → gpu POST /transcribe)
# HMAC secret SHARED between the gpu-gigaam signer and the webhook-receiver verifier.
GIGAAM_WEBHOOK_SECRET=replace_with_long_random_hex         # SECRET # founder-gated
# Public base the GPU posts its callback to; receiver path /gpu/callback is appended.
WEBHOOK_PUBLIC_URL=https://webhook.fliphouse.example       # founder-gated

# Graceful-drain knobs (graceful redeploy — see apps/worker-node/DEPLOY.md).
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=120                    # grace between SIGTERM and SIGKILL (SET THIS > longest stage)
WORKER_SHUTDOWN_DEADLINE_MS=30000                          # backstop force-exit (default 30000; set just under draining*1000)

# Baked into the worker image (do NOT override unless you know why):
#   FLIPHOUSE_PYTHON=/usr/bin/python3   NODE_ENV=production

# -----------------------------------------------------------------------------
# hook-receiver (apps/hook-receiver)  — tusd post-finish HTTP hook
# Reads DATABASE_URL + REDIS_URL (above). requireEnv throws on either missing.
# -----------------------------------------------------------------------------
# Optional sweep cadence overrides (reconcile orphaned flows). Defaults shown.
SWEEP_GRACE_TTL_MS=300000                                  # (optional, default 300000)
SWEEP_INTERVAL_MS=60000                                    # (optional, default 60000)

# -----------------------------------------------------------------------------
# webhook-receiver (apps/webhook-receiver)  — GPU /gpu/callback HTTP service
# Reads GIGAAM_WEBHOOK_SECRET + REDIS_URL + R2_* (all above). requireEnv +
# resolveR2Env throw on the first missing. Same secret as the GPU signer.
# -----------------------------------------------------------------------------
# (no service-unique vars beyond GIGAAM_WEBHOOK_SECRET / REDIS_URL / R2_*)

# -----------------------------------------------------------------------------
# gpu-gigaam (services/gpu-gigaam)  — FOUNDER-GATED GPU transcription service
# -----------------------------------------------------------------------------
# Same HMAC secret as the webhook-receiver (must be byte-identical on both sides).
# GIGAAM_WEBHOOK_SECRET=...                                # SECRET # founder-gated (see above)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx                           # SECRET # founder-gated (gated pyannote VAD models)

# -----------------------------------------------------------------------------
# Shared HTTP bind (the three receiver/HTTP services). Leave unset on Railway —
# it injects PORT and `::` dual-stack is the default HOST.
# -----------------------------------------------------------------------------
HOST=::                                                    # (optional; defaults to `::` dual-stack)
PORT=8080                                                  # (Railway injects this; defaults to 8080)

# -----------------------------------------------------------------------------
# Shared runtime mode (all Node services).
# -----------------------------------------------------------------------------
NODE_ENV=production                                        # test | development | production
