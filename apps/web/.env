# FlipHouse `web` — committed non-secret defaults.
# Real secrets go in `.env.local` (gitignored). Production env is injected by Railway.

# Clerk authentication (publishable key is public/client-side).
# FlipHouse Clerk app: app_3F95DjSclyWOw7eHFfF8Af5XrNH — swap to its pk_… when available.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_b3Blbi1zdGlua2J1Zy04LmNsZXJrLmFjY291bnRzLmRldiQ

# Database — ephemeral local PGlite over TCP. High port 54329 dodges a host
# Postgres (5432) / Docker. Production uses the Railway Postgres private URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54329/postgres

# Redis — private network URL in production (Railway: ${{Redis.REDIS_PRIVATE_URL}}).
# Local default points at a dev Redis; health reports redis 'down' if none is running.
REDIS_PRIVATE_URL=redis://127.0.0.1:6379

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

# Billing — crypto prepaid balance (P1.12). `mock` derives deterministic deposit
# addresses with no network/keys; production sets PAYMENT_PROVIDER=tron once the
# on-chain TRON provider lands (P1.13/checkpoint F). BILLING_PLAN_ENV optionally
# overrides the plan grid as JSON.
PAYMENT_PROVIDER=mock

# TRON on-chain deposit watcher (P1.13). USDT TRC-20 contract a deposit must match,
# confirmations gate before crediting, and the network. Real polling + the secret
# TRONGRID_API_KEY (.env.local only) land at checkpoint F on a testnet (Nile/Shasta).
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_CONFIRMATIONS=19
TRON_NETWORK=nile

######## [BEGIN] SENSITIVE DATA — do NOT put real secrets here. Use `.env.local`.
# Placeholder so T3 Env validation passes; real key lives in `.env.local`.
CLERK_SECRET_KEY=your_clerk_secret_key
######## [END] SENSITIVE DATA
