{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:next": "next dev",
    "dev": "pglite-server -m 100 -p 54329 --db=local.db --run 'run-s db:migrate dev:next'",
    "build:next": "next build",
    "build": "pglite-server -m 100 -p 54329 --run 'run-s db:migrate build:next'",
    "start": "next start -H ::",
    "clean": "rimraf .next out coverage",
    "tokens": "node style-dictionary.config.mjs",
    "check:types": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:lighthouse": "node scripts/lighthouse.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@clerk/localizations": "^4.6.7",
    "@clerk/nextjs": "^7.4.0",
    "@fliphouse/db": "workspace:*",
    "@clerk/shared": "4.17.1",
    "@clerk/ui": "^1.13.0",
    "@fliphouse/shared": "workspace:*",
    "@logtape/logtape": "^2.1.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-nextjs": "^0.13.11",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "hash-wasm": "^4.12.0",
    "ioredis": "^5.11.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "tailwind-merge": "^3.6.0",
    "tronweb": "^6.3.0",
    "tus-js-client": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.1",
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "chrome-launcher": "^1.2.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "style-dictionary": "^5.4.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
