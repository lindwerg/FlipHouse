{
  "name": "@fliphouse/worker-node",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./flow": {
      "types": "./dist/flow/flow-producer.d.ts",
      "import": "./dist/flow/flow-producer.js",
      "default": "./dist/flow/flow-producer.js"
    },
    "./flow/build-flow-tree": {
      "types": "./dist/flow/build-flow-tree.d.ts",
      "import": "./dist/flow/build-flow-tree.js",
      "default": "./dist/flow/build-flow-tree.js"
    },
    "./queues": {
      "types": "./dist/queues/worker-pool.d.ts",
      "import": "./dist/queues/worker-pool.js",
      "default": "./dist/queues/worker-pool.js"
    }
  },
  "scripts": {
    "start": "node dist/worker/run-workers.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@fliphouse/db": "workspace:*",
    "@fliphouse/shared": "workspace:*",
    "bullmq": "^5.78.1",
    "ioredis": "^5.11.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "testcontainers": "^11.0.0"
  }
}
