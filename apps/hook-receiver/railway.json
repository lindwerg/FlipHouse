{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/hook-receiver/Dockerfile"
  },
  "deploy": {
    "startCommand": "node --enable-source-maps dist/server.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
